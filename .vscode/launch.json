{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/app/main.go",
      "envFile": "${workspaceFolder}/backend/.env",
      "args": [],
      "showLog": false
    },
    {
      "name": "Launch Frontend",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend/app",
      // "runtimeExecutable": "C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe"
    },
    {
      "type": "node",
      "name": "Launch Program Frontend",
      "cwd": "${workspaceFolder}/frontend",
      "program": "${workspaceFolder}/frontend/node_modules/nuxt/bin/nuxt.mjs",
      "request": "launch",
      "outputCapture": "std",
      "args": ["dev"]
    }
  ]
}
